// ============================================================
//  CONSONANTS
// ============================================================

// Ð³ â€” voiced velar stop
phoneme g
  vcd vel stp
  voicingswitch k
  lengthmod 5
  Vowelin f1=2  f2=2300 200 300  f3=-300 80
  Vowelout f1=2  f2=2300 250 300  f3=-300 80 brk

  IF nextPh(isPause2) THEN
    FMT(g/g_) addWav(x/g_)
  ENDIF
  FMT(g/g) addWav(x/g3, 90)
endphoneme

// Ð» â€” voiced lateral fricative /É®/ (approximated with lateral formants)
phoneme l
  ipa É®
  liquid
  lengthmod 7
  FMT(l/l)
endphoneme

// Ñ€ â€” alveolar trill
phoneme r
  ipa r
  liquid rhotic alv trl
  lengthmod 7
  length 80
  FMT(r3/r_trill, 80) addWav(r3/r_trill.wav, 50)
endphoneme

// Ñ… â€” voiceless velar fricative
phoneme x
  ipa x
  vls vel frc
  lengthmod 3
  Vowelin f1=0  f2=2300 200 400  f3=-100 80
  Vowelout f1=0 f2=2300 300 400  f3=-100 80  rms=20
  WAV(ufric/x_hr, 30)
endphoneme

// Ñ† â€” voiceless alveolar affricate /ts/
phoneme ts
  import_phoneme consonants/ts
endphoneme
