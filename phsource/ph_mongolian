// ============================================================
//  VOWELS â€” Short
// ============================================================

// Ð° /É‘/ â€” back open vowel
phoneme a
  ipa É‘
  vwl starttype #a endtype #a
  length 180
  FMT(vowel/aa)
endphoneme

// Ñ /e/ â€” front mid vowel
phoneme e
  ipa e
  vwl starttype #e endtype #e
  length 170
  FMT(vowel/e)
endphoneme

// Ð¸ /i/ â€” front close vowel
phoneme i
  ipa i
  vwl starttype #i endtype #i
  length 170
  FMT(vowel/i)
endphoneme

// Ð¾ /É”/ â€” back mid-open rounded
phoneme O
  ipa É”
  vwl starttype #o endtype #o
  length 180
  FMT(vowel/oo)
endphoneme

// ө /ɵ/ — close-mid central rounded (+ATR)
phoneme 8
  ipa ɵ
  vwl starttype #@ endtype #@
  length 180
  FMT(vowel/8)
endphoneme

// Ñƒ /ÊŠ/ â€” back near-close rounded
phoneme U
  ipa ÊŠ
  vwl starttype #u endtype #u
  length 180
  FMT(vowel/uu_2)
endphoneme

// ү /u/ — close back rounded (+ATR)
phoneme y
  ipa u
  vwl starttype #u endtype #u
  length 170
  FMT(vowel/u_bck)
endphoneme

