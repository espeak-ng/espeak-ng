// Sicilian phoneme additions.
// This file is UTF-8 encoded.

phoneme e
  vwl starttype #e endtype #e
  length 150
  ipa ɛ
  FMT(vwl_it/e_open)
endphoneme

phoneme e/
  vwl starttype #e endtype #e
  length 145
  ipa ɛ
  FMT(vwl_it/e_open)
endphoneme

