  Vowelin  f1=2  f2=1700 -200 250  f3=-100 60
  Vowelout f1=2  f2=1700 -200 250  f3=-100 60  rms=20 brk

  IF nextPh(isPause2) THEN
    FMT(voc/z_) addWav(ufric/s_, 170)
  ENDIF
  FMT(voc/z) addWav(ufric/s_, 240)
endphoneme

phoneme l:
  liquid
  lengthmod 9
  length 170
  ipa lː
  IF nextPh(isNotVowel) THEN
    ChangePhoneme(l/)
  ENDIF

  NextVowelStarts
    VowelStart(l/l@)
    VowelStart(l/la, -10)
    VowelStart(l/le, -15)
    VowelStart(l/li, -15)
    VowelStart(l/lo, -20)
    VowelStart(l/lu, -17)
  EndSwitch
  IF prevPh(#@) THEN
    VowelEnding(l/xl, -50)
  ELIF prevPh(isVowel) THEN
    VowelEnding(l/xl, -40)
  ENDIF

  IF prevPh(isPause) THEN
    FMT(l/_l)
  ENDIF

  IF prevPh(t) THEN
    FMT(l/tl)
  ENDIF

  FMT(l/l_long)
  FMT(l/l)
endphoneme

phoneme N:
  vcd vel nas
  lengthmod 9
  length 170
  ipa ŋː
  Vowelout f1=3 f2=2300 300 400  f3=-200 80  len=40 rms=20 brk

  IF KlattSynth THEN
    Vowelin f1=0 f2=2100 50 300 f3=0 80
    IF nextPh(isPause2) THEN
      FMT(klatt/nn_)
    ENDIF
    FMT(klatt/nn)
  ENDIF

  NextVowelStarts
    VowelStart(nn/nn@)
    VowelStart(nn/nna)
    VowelStart(nn/nne)
    VowelStart(nn/nni)
    VowelStart(nn/nno)
    VowelStart(nn/nnu)
  EndSwitch

  IF prevPh(#i) THEN
    VowelEnding(nn/inn, -40)
  ENDIF

  IF prevPh(isNotVowel) AND nextPhW(isLiquid) THEN
    FMT(nn/nnj)
  ELIF prevPh(isPause) THEN
    FMT(nn/_nn)
  ELIF nextPh(isNotVowel) THEN
    FMT(nn/nn_, 170)
  ELSE
    FMT(nn/nnj, 170)
  ENDIF
endphoneme

