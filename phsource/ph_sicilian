  voicingswitch z
  lengthmod 3
  ipa sː
  Vowelin  f1=0  f2=1700 -300 300  f3=-100 90
  Vowelout f1=2  f2=1700 -200 250  f3=-100 60  rms=20
  length 140
  WAV(ufric/s, 75)
endphoneme

phoneme s:
