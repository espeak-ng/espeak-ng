  Vowelout f1=0 f2=1800 -300 250  f3=-400 80  rms=20 colr=2
  WAV(ustop/t_short)
endphoneme

phoneme d.0
  vcd rfx stp unx
  lengthmod 7
  voicingswitch t.
  length 85
  ipa ɖ̚
  Vowelin f1=1  f2=1500 -500 350  f3=-650 110
  Vowelout f1=1 f2=1500 -500 350  f3=-650 110 colr=2 brk
  FMT(d/xdr, 70)
endphoneme

phoneme d.
  vcd rfx stp
  lengthmod 5
  voicingswitch t.
  ipa ɖ
  Vowelin f1=1  f2=1500 -500 350  f3=-650 110
  Vowelout f1=1 f2=1500 -500 350  f3=-650 110 colr=2

  IF PreVoicing THEN
    FMT(d/xdr)
  ENDIF

  IF nextPh(isPause2) THEN
    FMT(d/d_) addWav(x/d_)
  ENDIF

  FMT(d/dr2, 70) addWav(x/d, 60)
endphoneme

phoneme f:
  vls lbd frc
  voicingswitch v:
  lengthmod 3
  length 140
  ipa fː
  Vowelout f1=0  f2=1000 -500 -350  f3=-200 80

  IF nextPh(isPause) THEN
    WAV(ufric/f_, 75)
  ENDIF
  WAV(ufric/f, 75)
endphoneme

phoneme v:
  vcd lbd frc
  voicingswitch f:
  lengthmod 6
  length 140
  ipa vː
  Vowelin  f1=0  f2=1000 -300 -200  f3=-300 100
  Vowelout f1=0  f2=1000 -500 -300  f3=-300 60  len=50

  IF KlattSynth THEN
    Vowelout f1=1  f2=1000 -500 -300  f3=-300 60  len=50 brk
    IF nextPh(isPause2) THEN
      FMT(klatt/v_) addWav(vocw/v)
    ENDIF
    FMT(klatt/v) addWav(vocw/v, 150)
  ENDIF

  IF nextPh(isPause2) THEN
    FMT(voc/v_) addWav(vocw/v, 90)
  ENDIF
  FMT(voc/v) addWav(vocw/v, 90)
endphoneme

phoneme ss
