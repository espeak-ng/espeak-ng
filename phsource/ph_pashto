// ph_pashto - Phoneme table for Pashto language
// Created: March 2024

// This file defines phonemes specific to Pashto language
// It combines elements from Urdu, Persian, and Hindi phoneme sets
// with adjustments for Pashto-specific sounds

//====================================================
// VOWELS
//====================================================

phoneme a
  vwl starttype #a endtype #a
  length 180
  FMT(vowel/a)
endphoneme

phoneme a:
  vwl starttype #a endtype #a
  length 280
  FMT(vowel/a_2)
endphoneme

phoneme e
  vwl starttype #e endtype #e
