//====================================================
// CONSONANTS SPECIFIC TO PASHTO
//====================================================

phoneme ts
  // څ in Pashto
  vls alv afr
  lengthmod 2
  Vowelin f1=0  f2=1700 -300 300  f3=-100 80
  Vowelout f1=0 f2=1700 -300 250  f3=-100 80  rms=20
  WAV(ustop/ts)
endphoneme

phoneme dz
  // ځ in Pashto
  vcd alv afr
  lengthmod 5
  Vowelin f1=1  f2=1700 -300 300  f3=-100 80
  Vowelout f1=1 f2=1700 -300 300  f3=-100 80
  WAV(ustop/dz)
endphoneme

phoneme t.
  // ټ in Pashto
  vls pla stp
  lengthmod 2
  Vowelin f1=0  f2=1800 -300 300  f3=-200 80
  Vowelout f1=0 f2=1800 -300 250  f3=-200 80  rms=20
  WAV(ustop/t_pzd)
endphoneme

phoneme d.
  // ډ in Pashto
  vcd pla stp
  lengthmod 5
  Vowelin f1=2  f2=1800 -300 300  f3=-200 80
  Vowelout f1=2 f2=1800 -300 300  f3=-200 80
  WAV(ustop/d_pzd)
endphoneme

phoneme r.
  // ړ in Pashto
  vcd rfx flp
  lengthmod 6
  Vowelin f1=3  f2=1200 -400 -100  f3=-400 80
  Vowelout f1=3 f2=1200 -400 -100  f3=-400 80
  FMT(vnasal/nr) addWav(ustop/t_pzd_rfx, 60)
endphoneme

phoneme n.
  // ڼ in Pashto
  vcd rfx nas
  lengthmod 6
  Vowelin f1=3  f2=1200 -500 -300  f3=-400 80
  Vowelout f1=3 f2=1200 -500 -300  f3=-400 80
  FMT(vnasal/nr)
endphoneme

phoneme S;
  // ښ in Pashto  
  vls pla frc
  lengthmod 3
  Vowelin f1=0  f2=2700 -400 600  f3=-1000 80
  Vowelout f1=0 f2=2700 -400 600  f3=-1000 80
  WAV(ufric/sh)
endphoneme

phoneme Q
  // غ/ږ in Pashto
  vcd uvl frc
  lengthmod 6
  Vowelin f1=2  f2=1000 -500 -350  f3=-200 80
  Vowelout f1=2 f2=1000 -500 -350  f3=-200 80
  FMT(voc/Q) addWav(ufric/xx, 75)
endphoneme

phoneme g
  // ګ in Pashto
  vcd vel stp
  lengthmod 5
  Vowelin f1=2  f2=2300 200 300  f3=-300 80
  Vowelout f1=2  f2=2300 250 300  f3=-300 80
  IF nextPh(isPause2) THEN
    WAV(ustop/g_)
  ENDIF
  WAV(ustop/g)
endphoneme

